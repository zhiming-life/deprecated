# 复制本文件为 .env 并填上你自己的值（.env 已在 .gitignore，不会入库）

# 必填：API key（默认接 DeepSeek，到 https://platform.deepseek.com 申请）
ZHIMING_LIFE_API_KEY=sk-your-key-here

# 可选：API base url（默认 https://api.deepseek.com/v1）
# OpenAI 例：    https://api.openai.com/v1
# 本地 Ollama 例：http://localhost:11434/v1
ZHIMING_LIFE_BASE_URL=https://api.deepseek.com/v1

# 可选：模型名（默认 deepseek-chat）
ZHIMING_LIFE_MODEL=deepseek-chat
